# --- StratisIO Cloud Credentials Template ---
# Copy this file to .env and fill in your real credentials.
# If these are missing, the system falls back to SIMULATION mode.

# AWS Configuration (Boto3)
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1

# Azure Configuration (Azure SDK)
AZURE_TENANT_ID=your_tenant_id
AZURE_CLIENT_ID=your_client_id
AZURE_CLIENT_SECRET=your_client_secret
AZURE_SUBSCRIPTION_ID=your_subscription_id

# Resource Groups & Locations
AZURE_RESOURCE_GROUP=StratisioResources
AZURE_LOCATION=eastus
